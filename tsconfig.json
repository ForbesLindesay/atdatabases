{
  "compilerOptions": {
    "target": "es2019",
    "module": "preserve",
    "moduleResolution": "bundler",
    "declaration": true,
    "isolatedDeclarations": true,
    "isolatedModules": true,
    "sourceMap": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["es2020", "dom"],
    "pretty": true,
    "types": ["node"],
  }
}
